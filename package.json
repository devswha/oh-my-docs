{
  "name": "oh-my-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for managing Oh My Codex, Oh My Claude Code, Oh My OpenAgent, Gajae-Code, and LazyCodex documentation together.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:codex": "npm --prefix apps/codex run dev",
    "dev:claudecode": "npm --prefix apps/claudecode run dev",
    "dev:openagent": "npm --prefix apps/openagent run dev",
    "dev:gajae-code": "npm --prefix apps/gajae-code run dev",
    "dev:lzx": "npm --prefix apps/lzx run dev",
    "build": "npm run build:codex && npm run build:claudecode && npm run build:openagent && npm run build:gajae-code && npm run build:lzx",
    "build:codex": "npm --prefix apps/codex run build",
    "build:claudecode": "npm --prefix apps/claudecode run build",
    "build:openagent": "npm --prefix apps/openagent run build",
    "build:gajae-code": "npm --prefix apps/gajae-code run build",
    "build:lzx": "npm --prefix apps/lzx run build",
    "lint": "npm run lint:codex && npm run lint:claudecode && npm run lint:openagent && npm run lint:gajae-code && npm run lint:lzx",
    "lint:codex": "npm --prefix apps/codex run lint",
    "lint:claudecode": "npm --prefix apps/claudecode run lint",
    "lint:openagent": "npm --prefix apps/openagent run lint",
    "lint:gajae-code": "npm --prefix apps/gajae-code run lint",
    "lint:lzx": "npm --prefix apps/lzx run lint",
    "docs:accuracy": "node scripts/docs-accuracy/check.mjs",
    "docs:accuracy:codex": "node scripts/docs-accuracy/check.mjs --app codex",
    "docs:accuracy:claudecode": "node scripts/docs-accuracy/check.mjs --app claudecode",
    "docs:accuracy:openagent": "node scripts/docs-accuracy/check.mjs --app openagent",
    "docs:accuracy:gajae-code": "node scripts/docs-accuracy/check.mjs --app gajae-code",
    "docs:accuracy:lzx": "node scripts/docs-accuracy/check.mjs --app lzx",
    "docs:accuracy:test": "node --test scripts/docs-accuracy/check.test.mjs scripts/docs-accuracy/integration.test.mjs scripts/docs-accuracy/redteam.test.mjs scripts/docs-accuracy/skill-consistency.test.mjs",
    "install:all": "npm install --prefix apps/codex && npm install --prefix apps/claudecode && npm install --prefix apps/openagent && npm install --prefix apps/gajae-code && npm install --prefix apps/lzx",
    "status": "git status --short --branch",
    "vercel:sync-links": "node scripts/vercel-sync-links.mjs",
    "vercel:configure:dry": "node scripts/vercel-configure-projects.mjs --dry-run",
    "vercel:configure:apply": "node scripts/vercel-configure-projects.mjs --apply",
    "vercel:deploy:codex": "node scripts/vercel-deploy.mjs codex",
    "vercel:deploy:claudecode": "node scripts/vercel-deploy.mjs claudecode",
    "vercel:deploy:openagent": "node scripts/vercel-deploy.mjs openagent",
    "vercel:deploy:gajae-code": "node scripts/vercel-deploy.mjs gajae-code",
    "vercel:deploy:lzx": "node scripts/vercel-deploy.mjs lzx",
    "vercel:deploy:all": "node scripts/vercel-deploy.mjs all",
    "vercel:deploy:codex:prod": "node scripts/vercel-deploy.mjs codex --prod",
    "vercel:deploy:claudecode:prod": "node scripts/vercel-deploy.mjs claudecode --prod",
    "vercel:deploy:openagent:prod": "node scripts/vercel-deploy.mjs openagent --prod",
    "vercel:deploy:gajae-code:prod": "node scripts/vercel-deploy.mjs gajae-code --prod",
    "vercel:deploy:lzx:prod": "node scripts/vercel-deploy.mjs lzx --prod"
  }
}
